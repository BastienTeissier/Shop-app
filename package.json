{
	"name": "ecom-carousel",
	"version": "0.0.1",
	"private": true,
	"description": "An e-commerce carousel example",
	"type": "module",
	"scripts": {
		"dev": "skybridge dev",
		"build": "skybridge build",
		"start": "skybridge start",
		"seed:products": "prisma db seed",
		"inspector": "mcp-inspector http://localhost:3000/mcp",
		"lint": "biome check .",
		"lint:fix": "biome check . --fix",
		"format": "biome format . --write",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"audit:ci": "pnpm audit --audit-level high",
		"check": "pnpm lint && pnpm typecheck && pnpm audit:ci",
		"test:integration": "dotenvx run -f .env.test -- prisma migrate reset --force --skip-seed && dotenvx run -f .env.test -- vitest run server/tests --no-file-parallelism",
		"test:unit": "vitest run --config web/vite.config.ts",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:reset": "prisma migrate reset",
		"db:seed": "prisma db seed",
		"db:studio": "prisma studio"
	},
	"dependencies": {
		"@biomejs/biome": "^2.3.11",
		"@modelcontextprotocol/sdk": "^1.25.2",
		"@prisma/client": "^5.22.0",
		"express": "^5.2.1",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"skybridge": ">=0.25.0 <1.0.0",
		"vite": "^7.3.1",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.4.2",
		"@testing-library/react": "^14.2.2",
		"@testing-library/user-event": "^14.5.2",
		"@modelcontextprotocol/inspector": "^0.18.0",
		"@skybridge/devtools": ">=0.22.0 <1.0.0",
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"@dotenvx/dotenvx": "^1.51.4",
		"happy-dom": "^20.4.0",
		"nodemon": "^3.1.11",
		"prisma": "^5.22.0",
		"shx": "^0.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"prisma": {
		"seed": "tsx scripts/load-products.ts"
	}
}
